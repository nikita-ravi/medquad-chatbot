# ── Required API Keys ─────────────────────────────────────────────────────────
# Get yours from: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── Qdrant Cloud ─────────────────────────────────────────────────────────────
# Get yours from: https://cloud.qdrant.io
QDRANT_URL=https://your-cluster-id.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to "docker" when running in a container (disables local Phoenix UI)
RUN_ENV=local
